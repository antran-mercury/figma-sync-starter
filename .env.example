# Figma Personal Access Token (read access)
FIGMA_TOKEN=your_figma_personal_access_token

# Figma file URL (preferred) — fileKey is parsed automatically from the URL.
# Supports: https://www.figma.com/file/<FILE_KEY>/... or https://www.figma.com/design/<FILE_KEY>/...
FIGMA_FILE_URL=https://www.figma.com/design/your_file_key/Your-File-Name

# Figma file key (fallback when FIGMA_FILE_URL is not set)
FIGMA_FILE_KEY=your_figma_file_key

# Comma-separated list of Figma node IDs to export (preferred scope).
# When set, only these nodes are fetched via the /nodes endpoint instead of the entire file.
# Example: FIGMA_NODE_IDS=123:456,789:101
FIGMA_NODE_IDS=