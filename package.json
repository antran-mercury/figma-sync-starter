{
  "name": "figma-sync-starter",
  "private": true,
  "type": "module",
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "figma:export": "node scripts/figma-export.mjs",
    "figma:diff": "node scripts/figma-diff.mjs",
    "figma:mapping:validate": "node scripts/validate-figma-mapping.mjs figma-mapping.json",
    "figma:sync": "node scripts/figma-sync.mjs",
    "ai:init": "node scripts/ai-prompt-init.mjs",
    "ai:sync": "node scripts/ai-prompt-sync.mjs",
    "figma:pipeline": "yarn figma:export && yarn figma:diff && node scripts/figma-pipeline.mjs",
    "designer:brief": "node scripts/designer-brief.mjs",
    "test:ui": "playwright test",
    "test:ui:update": "playwright test --update-snapshots",
    "ui:report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0"
  }
}